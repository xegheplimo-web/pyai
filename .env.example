# ============================================================
# MAS-OpenClaw Configuration - Optimized for your hardware
# AMD Ryzen 9 9950X | 96GB RAM | RTX 3090 24GB | 4TB SSD
# ============================================================

# --- Ollama Configuration ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
# Quantization: Q4_K_M (~8.5GB VRAM) leaves room for other tasks
# Upgrade to Q5_K_M (~10GB) or Q6_K (~12GB) for better quality
OLLAMA_NUM_GPU_LAYERS=99
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_FLASH_ATTENTION=true
# Context window: 8192 for speed, 32768 for deep research
OLLAMA_NUM_CTX=16384

# --- SearXNG Search Engine ---
SEARXNG_HOST=http://localhost:8888
SEARXNG_SECRET=$(openssl rand -hex 32)

# --- MAS Configuration ---
# Max concurrent agents (16 cores / 32 threads → 6-8 agents optimal)
MAS_MAX_CONCURRENT_AGENTS=6
# Agent timeout in seconds
MAS_AGENT_TIMEOUT=120
# Max search results per query
MAS_MAX_SEARCH_RESULTS=10
# Research depth: quick | standard | deep
MAS_RESEARCH_DEPTH=deep
# Enable source verification
MAS_VERIFY_SOURCES=true

# --- Model Parameters ---
MODEL_TEMPERATURE=0.3
MODEL_TOP_P=0.9
MODEL_TOP_K=40
MODEL_REPEAT_PENALTY=1.1
MODEL_NUM_PREDICT=4096

# --- Performance Tuning (RTX 3090 24GB) ---
# GPU memory utilization (0.85 = ~20.4GB of 24GB)
GPU_MEMORY_UTILIZATION=0.85
# CPU threads for inference
CPU_THREADS=12

# --- Web UI ---
STREAMLIT_PORT=8501
STREAMLIT_HOST=0.0.0.0

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=data/logs/mas.log

# --- Dual Model Strategy ---
# Light model for routing & simple tasks
OLLAMA_LIGHT_MODEL=qwen2.5:3b
# Heavy model for deep research (default)
OLLAMA_HEAVY_MODEL=qwen2.5:14b
# Enable dual model (true = use both, false = heavy only)
DUAL_MODEL_ENABLED=true

# --- Memory & Cache ---
# Cache research results (hours)
RESEARCH_CACHE_HOURS=24
# Cache search results (hours)
SEARCH_CACHE_HOURS=6
# Cleanup old data (days)
MEMORY_CLEANUP_DAYS=30

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Telegram Bot (optional) ---
TELEGRAM_BOT_TOKEN=
# Allowed user IDs (comma-separated, empty = all)
TELEGRAM_ALLOWED_USERS=

# --- Scheduled Research ---
SCHEDULED_ENABLED=false
